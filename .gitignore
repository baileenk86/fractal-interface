--- .gitignore (原始)


+++ .gitignore (修改后)
```
# Dependencies
node_modules/

# Build artifacts
dist/
build/
target/

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Coverage
.coverage
coverage/
htmlcov/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~
.DS_Store
Thumbs.db

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```